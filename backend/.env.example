DATABASE_URL=postgresql+asyncpg://breach_user:breach_pass@localhost:5432/breachreplay
SYNC_DATABASE_URL=postgresql://breach_user:breach_pass@localhost:5432/breachreplay

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini fallback — used automatically when Claude is unavailable or rate-limited
# Get key at: aistudio.google.com → Get API Key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PREFER_GEMINI=false  # set to true if Claude credits exhausted

SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

REDIS_URL=redis://localhost:6379/0

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=breachreplay-documents

SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@breachreplay.io

SENTRY_DSN=

SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_PUBLISHABLE_KEY=
SIEM_WEBHOOK_TIMEOUT=5

ENVIRONMENT=development
DEBUG=true
